@inherits LayoutComponentBase

<div class="app-shell">
    <header class="gh-header">
        <div class="gh-header-inner">
            <div class="gh-header-left">
                <a href="/" class="logo">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2L2 7v10l10 5 10-5V7L12 2z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                        <path d="M12 7l-5 2.5v5L12 17l5-2.5v-5L12 7z" fill="currentColor" opacity="0.3"/>
                        <path d="M12 7v10M7 9.5l5 2.5 5-2.5" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                    <span>OpenAPI Guard</span>
                </a>
                <nav class="gh-nav">
                    <a href="/projects" class="gh-nav-link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.25.25 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z"/></svg>
                        Projects
                    </a>
                </nav>
            </div>
            <div class="gh-header-right">
                <span class="gh-header-badge">MVP</span>
            </div>
        </div>
    </header>

    <main class="gh-main">
        <div class="gh-container">
            @Body
        </div>
    </main>

    <footer class="gh-footer">
        <div class="gh-footer-inner">
            <div class="gh-footer-brand">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2L2 7v10l10 5 10-5V7L12 2z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                    <path d="M12 7l-5 2.5v5L12 17l5-2.5v-5L12 7z" fill="currentColor" opacity="0.3"/>
                    <path d="M12 7v10M7 9.5l5 2.5 5-2.5" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                <span>&copy; @DateTime.UtcNow.Year OpenAPI Guard</span>
            </div>
            <nav class="gh-footer-nav">
                <a href="/projects">Dashboard</a>
                <span class="gh-footer-sep">&middot;</span>
                <a href="/docs">Docs</a>
                <span class="gh-footer-sep">&middot;</span>
                <a href="/api-docs">API</a>
                <span class="gh-footer-sep">&middot;</span>
                <a href="/privacy">Privacy</a>
                <span class="gh-footer-sep">&middot;</span>
                <a href="/terms">Terms</a>
            </nav>
            <div class="gh-footer-tagline">
                Detect breaking API changes before they ship.
            </div>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
