@page "/projects/{ProjectId:guid}/diffs/{DiffId:guid}"
@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Diff Report — OpenAPI Guard</PageTitle>

<div class="breadcrumb">
    <a href="/">Projects</a>
    <span>/</span>
    <a href="/projects/@ProjectId/specs">@projectName</a>
    <span>/</span>
    <a href="/projects/@ProjectId/diffs">Diffs</a>
    <span>/</span>
    @fromLabel → @toLabel
</div>

@if (report is null)
{
    <p class="text-muted">Loading…</p>
}
else
{
    <div class="page-header">
        <div>
            <h2>@fromLabel → @toLabel</h2>
            <div class="text-muted" style="margin-top: 2px;">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" style="vertical-align: -2px; margin-right: 4px;"><path d="M4.75 0a.75.75 0 0 1 .75.75V2h5V.75a.75.75 0 0 1 1.5 0V2h1.25c.966 0 1.75.784 1.75 1.75v10.5A1.75 1.75 0 0 1 13.25 16H2.75A1.75 1.75 0 0 1 1 14.25V3.75C1 2.784 1.784 2 2.75 2H4V.75A.75.75 0 0 1 4.75 0ZM2.5 7.5v6.75c0 .138.112.25.25.25h10.5a.25.25 0 0 0 .25-.25V7.5Zm10.75-4H2.75a.25.25 0 0 0-.25.25V6h11V3.75a.25.25 0 0 0-.25-.25Z"/></svg>
                @report.CreatedAt.ToString("MMMM dd, yyyy  ·  HH:mm")
            </div>
        </div>
        <div>
            @if (report.BreakingCount > 0)
            {
                <span class="badge badge-fail" style="font-size: 14px; padding: 6px 16px; font-weight: 700;">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" style="margin-right: 2px;"><path d="M3.72 3.72a.75.75 0 0 1 1.06 0L8 6.94l3.22-3.22a.749.749 0 0 1 1.275.326.749.749 0 0 1-.215.734L9.06 8l3.22 3.22a.749.749 0 0 1-.326 1.275.749.749 0 0 1-.734-.215L8 9.06l-3.22 3.22a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042L6.94 8 3.72 4.78a.75.75 0 0 1 0-1.06Z"/></svg>
                    FAIL
                </span>
            }
            else
            {
                <span class="badge badge-pass" style="font-size: 14px; padding: 6px 16px; font-weight: 700;">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" style="margin-right: 2px;"><path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z"/></svg>
                    PASS
                </span>
            }
        </div>
    </div>

    <div class="summary-box">
        <div class="summary-stat">
            <div class="number text-danger">@report.BreakingCount</div>
            <div class="label">Breaking</div>
        </div>
        <div class="summary-stat">
            <div class="number" style="color: var(--color-warning);">@report.WarningCount</div>
            <div class="label">Warnings</div>
        </div>
        <div class="summary-stat">
            <div class="number" style="color: var(--color-accent);">@report.InfoCount</div>
            <div class="label">Info</div>
        </div>
    </div>

    <div class="gh-tabs">
        <button class="@(filter == "all" ? "active" : "")" @onclick='() => filter = "all"'>
            All changes (@items.Count)
        </button>
        <button class="@(filter == "breaking" ? "active" : "")" @onclick='() => filter = "breaking"'>
            Breaking (@report.BreakingCount)
        </button>
        <button class="@(filter == "warning" ? "active" : "")" @onclick='() => filter = "warning"'>
            Warnings (@report.WarningCount)
        </button>
        <button class="@(filter == "info" ? "active" : "")" @onclick='() => filter = "info"'>
            Info (@report.InfoCount)
        </button>
    </div>

    @foreach (var item in FilteredItems)
    {
        <div class="diff-item @item.Severity">
            <div class="d-flex justify-between align-center">
                <span class="kind">@item.Kind.Replace("_", " ")</span>
                <span class="badge @BadgeClass(item.Severity)">@item.Severity</span>
            </div>
            <div class="target">@item.Target</div>
            <div class="message">@item.Message</div>
        </div>
    }

    @if (!FilteredItems.Any())
    {
        <div class="empty-state">
            <p>No items matching this filter.</p>
        </div>
    }
}

@code {
    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public Guid DiffId { get; set; }

    private string projectName = "…";
    private string fromLabel = "";
    private string toLabel = "";
    private DiffReport? report;
    private List<DiffItemView> items = [];
    private string filter = "all";

    private IEnumerable<DiffItemView> FilteredItems =>
        filter == "all" ? items : items.Where(i => i.Severity == filter);

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var project = await db.Projects.FindAsync(ProjectId);
        projectName = project?.Name ?? "Unknown";

        report = await db.DiffReports.FindAsync(DiffId);
        if (report is null) return;

        var fromSpec = await db.ApiSpecVersions.FindAsync(report.FromSpecId);
        var toSpec = await db.ApiSpecVersions.FindAsync(report.ToSpecId);
        fromLabel = fromSpec?.Label ?? "?";
        toLabel = toSpec?.Label ?? "?";

        try
        {
            var parsed = System.Text.Json.JsonSerializer.Deserialize<List<DiffItemView>>(
                report.SummaryJson,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            items = parsed ?? [];
        }
        catch
        {
            items = [];
        }
    }

    private static string BadgeClass(string severity) => severity switch
    {
        "breaking" => "badge-fail",
        "warning" => "badge-warning",
        "info" => "badge-info",
        _ => "badge-muted"
    };

    private sealed class DiffItemView
    {
        public string Severity { get; set; } = "";
        public string Kind { get; set; } = "";
        public string Target { get; set; } = "";
        public string Message { get; set; } = "";
    }
}
