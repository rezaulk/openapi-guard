@page "/"

<PageTitle>OpenAPI Guard — Catch Breaking API Changes Before They Ship</PageTitle>

<!-- Hero -->
<section class="landing-hero">
    <div class="landing-hero-badge">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0ZM1.5 8a6.5 6.5 0 1 0 13 0 6.5 6.5 0 0 0-13 0Zm4.879-2.773 4.264 2.559a.25.25 0 0 1 0 .428l-4.264 2.559A.25.25 0 0 1 6 10.559V5.442a.25.25 0 0 1 .379-.215Z"/></svg>
        Open-source &amp; self-hostable
    </div>
    <h1 class="landing-hero-title">
        Catch <span class="landing-gradient-text">breaking API changes</span><br />before they ship
    </h1>
    <p class="landing-hero-sub">
        Upload your OpenAPI v3 specs, compare versions side-by-side, and get instant reports on
        breaking changes, removed endpoints, type mismatches, and schema drift — all in one place.
    </p>
    <div class="landing-hero-actions">
        <a href="/projects" class="btn btn-primary btn-lg">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/></svg>
            Go to Dashboard
        </a>
        <a href="/docs" class="btn btn-outline btn-lg">
            Read the Docs
        </a>
    </div>

    <!-- Hero Visual: simulated diff report -->
    <div class="landing-hero-visual">
        <div class="landing-terminal">
            <div class="landing-terminal-bar">
                <span class="landing-dot landing-dot-red"></span>
                <span class="landing-dot landing-dot-yellow"></span>
                <span class="landing-dot landing-dot-green"></span>
                <span class="landing-terminal-title">diff-report.json</span>
            </div>
            <div class="landing-terminal-body">
                <div class="landing-diff-line landing-diff-meta">  OpenAPI Guard — Diff Report</div>
                <div class="landing-diff-line landing-diff-meta">  Comparing v1.0.0 → v2.0.0</div>
                <div class="landing-diff-line landing-diff-meta">  ──────────────────────────────</div>
                <div class="landing-diff-line landing-diff-breaking">✗ BREAKING  DELETE /pets/{id}  — Endpoint removed</div>
                <div class="landing-diff-line landing-diff-breaking">✗ BREAKING  GET /pets  param "limit" — Type changed: integer → string</div>
                <div class="landing-diff-line landing-diff-breaking">✗ BREAKING  GET /pets  response field "name" — Removed from schema</div>
                <div class="landing-diff-line landing-diff-warn">⚠ WARNING  GET /pets  param "status" — Changed from optional to required</div>
                <div class="landing-diff-line landing-diff-info">ℹ INFO     GET /pets  response field "breed" — Added to schema</div>
                <div class="landing-diff-line landing-diff-meta">  ──────────────────────────────</div>
                <div class="landing-diff-line landing-diff-breaking">  Result: FAIL — 3 breaking, 1 warning, 1 info</div>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="landing-section">
    <div class="landing-section-header">
        <h2>Everything you need to govern your APIs</h2>
        <p>From spec upload to CI/CD integration — a complete toolkit for API contract safety.</p>
    </div>

    <div class="landing-features">
        <div class="landing-feature-card">
            <div class="landing-feature-icon landing-feature-icon-blue">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
                </svg>
            </div>
            <h3>Spec Version Management</h3>
            <p>Upload OpenAPI v3 JSON or YAML specs, tag them with version labels, and keep a full history of every revision.</p>
        </div>

        <div class="landing-feature-card">
            <div class="landing-feature-icon landing-feature-icon-red">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
            </div>
            <h3>Breaking Change Detection</h3>
            <p>Instantly detect removed endpoints, type changes, missing fields, parameter shifts, and schema drift between any two versions.</p>
        </div>

        <div class="landing-feature-card">
            <div class="landing-feature-icon landing-feature-icon-green">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                </svg>
            </div>
            <h3>Configurable Rules</h3>
            <p>Fine-tune which changes are blockers vs. warnings. Enforce naming conventions, require error responses, and more.</p>
        </div>

        <div class="landing-feature-card">
            <div class="landing-feature-icon landing-feature-icon-purple">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
                </svg>
            </div>
            <h3>CI/CD Integration</h3>
            <p>Use the REST API to check for breaking changes in GitHub Actions, Azure Pipelines, or any CI system. Fail builds automatically.</p>
        </div>

        <div class="landing-feature-card">
            <div class="landing-feature-icon landing-feature-icon-orange">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </div>
            <h3>Self-Hosted Option</h3>
            <p>Keep your API specs on your own infrastructure. Deploy with Docker in minutes — no data ever leaves your network.</p>
        </div>

        <div class="landing-feature-card">
            <div class="landing-feature-icon landing-feature-icon-teal">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
                </svg>
            </div>
            <h3>Diff Reports</h3>
            <p>Visual, color-coded reports with severity badges — breaking, warning, and info — so you know exactly what changed and why it matters.</p>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="landing-section landing-section-alt">
    <div class="landing-section-header">
        <h2>How it works</h2>
        <p>Three simple steps to API contract safety.</p>
    </div>

    <div class="landing-steps">
        <div class="landing-step">
            <div class="landing-step-number">1</div>
            <div class="landing-step-content">
                <h3>Upload your specs</h3>
                <p>Paste or upload your OpenAPI v3 JSON/YAML. Tag each version with a label like <code>v1.0.0</code>.</p>
            </div>
            <div class="landing-step-visual">
                <div class="landing-mock-upload">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                    <span>openapi-v2.json</span>
                </div>
            </div>
        </div>

        <div class="landing-step">
            <div class="landing-step-number">2</div>
            <div class="landing-step-content">
                <h3>Compare versions</h3>
                <p>Select two spec versions to compare. The diff engine analyzes every endpoint, parameter, schema, and response.</p>
            </div>
            <div class="landing-step-visual">
                <div class="landing-mock-compare">
                    <span class="landing-mock-tag">v1.0.0</span>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" opacity="0.4"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    <span class="landing-mock-tag">v2.0.0</span>
                </div>
            </div>
        </div>

        <div class="landing-step">
            <div class="landing-step-number">3</div>
            <div class="landing-step-content">
                <h3>Review the report</h3>
                <p>Get an instant, categorized report: breaking changes, warnings, and informational notes — all in one view.</p>
            </div>
            <div class="landing-step-visual">
                <div class="landing-mock-result">
                    <span class="badge badge-fail" style="font-size: 13px;">3 Breaking</span>
                    <span class="badge badge-warn" style="font-size: 13px;">1 Warning</span>
                    <span class="badge badge-pass" style="font-size: 13px;">1 Info</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- What Gets Detected -->
<section class="landing-section">
    <div class="landing-section-header">
        <h2>What gets detected</h2>
        <p>Our diff engine catches every category of API contract change.</p>
    </div>

    <div class="landing-detect-grid">
        <div class="landing-detect-card landing-detect-breaking">
            <h4>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M2.343 13.657A8 8 0 1 1 13.657 2.343 8 8 0 0 1 2.343 13.657ZM6.03 4.97a.751.751 0 0 0-1.042.018.751.751 0 0 0-.018 1.042L6.94 8 4.97 9.97a.749.749 0 0 0 .326 1.275.749.749 0 0 0 .734-.215L8 9.06l1.97 1.97a.749.749 0 0 0 1.275-.326.749.749 0 0 0-.215-.734L9.06 8l1.97-1.97a.749.749 0 0 0-.326-1.275.749.749 0 0 0-.734.215L8 6.94Z"/></svg>
                Breaking Changes
            </h4>
            <ul>
                <li>Endpoint removed</li>
                <li>Response field removed</li>
                <li>Parameter type changed</li>
                <li>Optional → required parameter</li>
                <li>Response field type changed</li>
                <li>Request body schema changes</li>
            </ul>
        </div>
        <div class="landing-detect-card landing-detect-warning">
            <h4>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M6.457 1.047c.659-1.234 2.427-1.234 3.086 0l6.082 11.378A1.75 1.75 0 0 1 14.082 15H1.918a1.75 1.75 0 0 1-1.543-2.575ZM8 5a.75.75 0 0 1 .75.75v2.5a.75.75 0 0 1-1.5 0v-2.5A.75.75 0 0 1 8 5Zm0 6a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z"/></svg>
                Warnings
            </h4>
            <ul>
                <li>New required parameter added</li>
                <li>Request body field added (required)</li>
                <li>Deprecated endpoints</li>
                <li>Naming convention violations</li>
            </ul>
        </div>
        <div class="landing-detect-card landing-detect-info">
            <h4>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8Zm8-6.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13ZM6.5 7.75A.75.75 0 0 1 7.25 7h1a.75.75 0 0 1 .75.75v2.75h.25a.75.75 0 0 1 0 1.5h-2a.75.75 0 0 1 0-1.5h.25v-2h-.25a.75.75 0 0 1-.75-.75ZM8 6a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z"/></svg>
                Informational
            </h4>
            <ul>
                <li>New endpoint added</li>
                <li>New optional response field</li>
                <li>New optional parameter</li>
                <li>Description changes</li>
            </ul>
        </div>
    </div>
</section>

